# Copy to .env for local dev. On Render, set these in the dashboard
# (Environment) or via render.yaml. All are server-side only — never exposed
# to the browser. Every feature degrades gracefully when a var is missing.

# --- Reddit lead finder (free) ---
# Reddit blocks anonymous .json access, so OAuth is required.
# Create a FREE "script" app: https://www.reddit.com/prefs/apps -> "create app"
#   type: script    redirect uri: http://localhost   (required but unused)
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USER_AGENT=web:outbound-cockpit:v1 (by /u/your_reddit_username)

# --- Apollo lead finder (paid plan with API access) ---
# https://app.apollo.io/#/settings/integrations/api
# APOLLO_API_KEY=your_apollo_api_key

# --- Apify (optional) — gated LinkedIn PROFILE scrape for AI analyse ---
# Feeds the prospect's real LinkedIn profile (headline/About/posts) into the
# AI brief, on-demand (the "Pull LinkedIn profile" checkbox). Pay-per-result.
# Token: https://console.apify.com/account/integrations
# IMPORTANT: pick a PUBLIC-profile actor (proxy-based). Never use an actor that
# requires your LinkedIn session cookie (li_at) — that risks an account ban.
# APIFY_TOKEN=apify_api_...
# APIFY_LINKEDIN_PROFILE_ACTOR=apimaestro~linkedin-profile-detail
# APIFY_LINKEDIN_POSTS_ACTOR=harvestapi~linkedin-profile-posts
# Intent sourcing — search LinkedIn POSTS by keyword; post authors become leads
# (Leads tab -> "Find by LinkedIn posts"). Same Apify token, pay-per-result.
# APIFY_LINKEDIN_POST_SEARCH_ACTOR=harvestapi~linkedin-post-search

# --- AI analyse (optional) — deep prospect research + drafts a message ---
# The cockpit auto-detects whichever key is present (priority: Perplexity ->
# OpenAI -> Anthropic -> built-in heuristic). Without one it falls back to the
# heuristic (works, but no research and a flat fit score).
# Preferred — Perplexity sonar does LIVE web research (website, LinkedIn,
# Twitter/X, news, funding, hiring) and returns sources.
# https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_MODEL=sonar-pro               # standard analyse (or sonar / sonar-reasoning-pro)
# PERPLEXITY_DEEP_MODEL=sonar-deep-research # used when "Deep research" is ticked in the UI
# Fallbacks — reason over Apollo facts + website text only (no live search):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini                 # optional override
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest  # optional override

# --- Cross-device sync (optional) ---
# Without these the cockpit just uses the browser's localStorage.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=outbound_cockpit
# COCKPIT_TOKEN=secret          # Mongo /api/cockpit sync only (Setup tab in UI)
# COCKPIT_UI_AUTH=1             # + COCKPIT_TOKEN → browser login popup (off by default)

# OUTREACH_VOICE_NAME=Alex          # name used in draft messages (default: "the operator")
# OUTBOUND_COMPANY_NAME=Acme Studio  # company context in prompts (default: "your team")
# OUTBOUND_OFFER_CONTEXT=...         # optional override for internal fit context (never pitched)
# AGENT_SERVICE_URL=http://localhost:8000
# AGENT_FALLBACK=1                    # fall back to legacy /api/ai/* on agent errors
# COCKPIT_SERVICE_TOKEN=shared_secret # REQUIRED for agent — same on Node + Python (NOT a browser password)

# PORT is provided automatically by Render. Locally defaults to 3000.
# PORT=3000
